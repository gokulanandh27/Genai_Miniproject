@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  color-scheme: dark;
}

body {
  @apply bg-background text-gray-200 font-sans antialiased;
}

/* Glassmorphism utility */
.glass {
  @apply bg-white/5 backdrop-blur-xl border border-white/10 shadow-2xl;
}

.glow-accent {
  @apply shadow-[0_0_20px_rgba(99,102,241,0.3)];
}
